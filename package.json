{
  "name": "my-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "components/**/*.js",
      "screen/**/*.js",
      "navigation/**/*.js",
      "context/**/*.js",
      "services/**/*.js",
      "redux/**/*.js",
      "utils/**/*.js",
      "!**/node_modules/**",
      "!**/coverage/**"
    ],
    "coverageReporters": [
      "html",
      "text"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!react-native|@react-native|expo|@expo|@react-navigation)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/firestore": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-firebase/remote-config": "^24.0.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/drawer": "^7.8.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.6",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.10.0",
    "jest-expo": "~54.0.17",
    "lodash": "^4.17.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "styled-components": "^6.3.10",
    "yup": "^1.7.1"
  },
  "private": true,
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "jest": "^29.7.0",
    "react-test-renderer": "^19.1.0"
  }
}
